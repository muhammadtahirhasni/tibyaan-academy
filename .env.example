# =============================================================================
# Tibyaan Academy — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (Authentication + Storage)
# https://supabase.com/dashboard → Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Neon PostgreSQL (Database)
# https://console.neon.tech → Connection Details
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# -----------------------------------------------------------------------------
# Anthropic Claude AI (AI Ustaz + Blog Generation)
# https://console.anthropic.com → API Keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Groq (Whisper Large v3 — Audio Transcription)
# https://console.groq.com → API Keys
# -----------------------------------------------------------------------------
GROQ_API_KEY=gsk_...

# -----------------------------------------------------------------------------
# Stripe (Payments)
# https://dashboard.stripe.com → Developers → API Keys
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# Resend (Transactional Email)
# https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Cron & Admin Secrets
# Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
CRON_SECRET=your-cron-secret
ADMIN_SECRET=your-admin-secret

# -----------------------------------------------------------------------------
# Sentry (Error Tracking — Optional)
# https://sentry.io → Settings → Client Keys (DSN)
# -----------------------------------------------------------------------------
SENTRY_DSN=https://your-key@sentry.io/your-project
NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project
