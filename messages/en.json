  "privacyPage": {
    "title": "Privacy Policy",
    "lastUpdated": "Last updated: March 2026",
    "section1Title": "Information We Collect",
    "section1Content": "We collect personal information you provide when creating an account, including your name, email address, and payment information. We also collect usage data such as lesson progress, quiz scores, and learning analytics to improve your experience.",
    "section2Title": "How We Use Your Information",
    "section2Content": "Your information is used to provide and improve our educational services, process payments, communicate with you about your account and classes, and personalize your learning experience. We never sell your personal data to third parties.",
    "section3Title": "Data Security",
    "section3Content": "We implement industry-standard security measures to protect your personal information. All data is encrypted in transit and at rest. Payment processing is handled by Stripe, a PCI-compliant payment processor.",
    "section4Title": "Children's Privacy",
    "section4Content": "We take children's privacy seriously. For students under 13, we require parental consent before account creation. Parents can review, modify, or delete their child's information at any time by contacting us.",
    "section5Title": "Contact Us",
    "section5Content": "If you have questions about this privacy policy or your personal data, please contact us at support@tibyaan.com. We will respond to your inquiry within 30 days."
  },
  "termsPage": {
    "title": "Terms & Conditions",
    "lastUpdated": "Last updated: March 2026",
    "section1Title": "Acceptance of Terms",
    "section1Content": "By accessing and using Tibyaan Academy's services, you agree to be bound by these terms and conditions. If you do not agree with any part of these terms, you may not use our services.",
    "section2Title": "Account & Subscriptions",
    "section2Content": "You are responsible for maintaining the confidentiality of your account credentials. Subscription plans are billed monthly or yearly as selected. You may cancel your subscription at any time, and access will continue until the end of the current billing period.",
    "section3Title": "Class Policies",
    "section3Content": "Live classes are scheduled between you and your assigned teacher. If you need to reschedule, please notify us at least 4 hours in advance. Missed classes without prior notice may not be rescheduled. We reserve the right to reassign teachers if needed.",
    "section4Title": "Acceptable Use",
    "section4Content": "You agree to use our platform respectfully and in accordance with Islamic values. Any form of harassment, inappropriate behavior, or misuse of the AI Ustaz system may result in account suspension or termination.",
    "section5Title": "Limitation of Liability",
    "section5Content": "Tibyaan Academy provides educational services on an 'as-is' basis. While we strive for excellence, we do not guarantee specific learning outcomes. Our liability is limited to the amount paid for services in the preceding 12 months."
